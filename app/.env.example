# Database
DATABASE_URL=postgresql://<user>:<password>@db:5432/orientapi
POSTGRES_USER=orientapi
POSTGRES_PASSWORD=changeme
POSTGRES_DB=orientapi

# JWT
JWT_SECRET=<random-secret-min-32-chars>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# API credentials
API_USERNAME=<username>
API_PASSWORD=<password>

# Grafana (variables natives lues directement par le conteneur Grafana)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=<password>

# Argo CD (injecté via cloud-init / terraform.tfvars en infra)
ARGOCD_ADMIN_USER=admin
ARGOCD_ADMIN_PASSWORD=<password>
