{
  "title": "OrientAPI — Santé API",
  "uid": "orientapi-health",
  "description": "Taux de requêtes, latence et taux d'erreur de l'API OrientAPI",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["orientops", "api"],
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Taux de requêtes (req/s)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count{job=\"orientapi\"}[5m])) by (handler)",
          "legendFormat": "{{ handler }}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Latence P95 (ms)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "P95" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"orientapi\"}[5m])) by (le, handler)) * 1000",
          "legendFormat": "P95 {{ handler }}"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"orientapi\"}[5m])) by (le, handler)) * 1000",
          "legendFormat": "P50 {{ handler }}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Taux d'erreur 5xx (%)",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count{job=\"orientapi\", status=~\"5..\"}[5m])) / sum(rate(http_request_duration_seconds_count{job=\"orientapi\"}[5m])) * 100",
          "legendFormat": "Erreurs 5xx"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Pods actifs",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(up{job=\"orientapi\"} == 1)",
          "legendFormat": "Pods"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Répartition par code HTTP",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count{job=\"orientapi\"}[5m])) by (status)",
          "legendFormat": "HTTP {{ status }}"
        }
      ]
    }
  ]
}
