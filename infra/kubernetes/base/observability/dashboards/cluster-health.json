{
  "title": "OrientOps — Santé Cluster",
  "uid": "orientops-cluster",
  "description": "CPU, mémoire, redémarrages de pods et pression du nœud k3s",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["orientops", "cluster"],
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Mémoire par pod — namespace orientapi (MiB)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "decmbytes", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{namespace=\"orientapi\", container!=\"\"} / 1024 / 1024",
          "legendFormat": "{{ pod }} / {{ container }}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU par pod — namespace orientapi (millicores)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"orientapi\", container!=\"\"}[5m]) * 1000",
          "legendFormat": "{{ pod }} / {{ container }}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Redémarrages de pods (24h)",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"orientapi\"}[24h]))",
          "legendFormat": "Redémarrages"
        }
      ]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Mémoire nœud utilisée (%)",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "RAM utilisée"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Mémoire nœud — disponible vs totale (GiB)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "decgbytes", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes / 1024 / 1024 / 1024",
          "legendFormat": "Total"
        },
        {
          "expr": "node_memory_MemAvailable_bytes / 1024 / 1024 / 1024",
          "legendFormat": "Disponible"
        }
      ]
    }
  ]
}
